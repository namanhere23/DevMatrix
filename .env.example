# ═══════════════════════════════════════════════
# NexusSentry — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# You only need ONE provider key — the system auto-detects
# which are available and routes accordingly.

# ── LLM Provider Keys (at least ONE required) ──
# Set whichever keys you have. System auto-selects the best one.

# Google Gemini (fastest, cheapest — recommended for demo)
GEMINI_API_KEY=your_gemini_key_here

# Groq (fast reasoning)
GROQ_API_KEY=your_groq_key_here

# OpenRouter (access to 100+ models)
OPENROUTER_API_KEY=your_openrouter_key_here

# Anthropic Claude (premium fallback)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Telegram HITL (Optional) ──
NEXUSAGENT_TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Claw Code binary path (Optional) ──
# If not set, runs in demo mock mode
CLAW_BINARY=./claw-code/rust/target/release/claw

# ── Response Cache (Optional) ──
# Set to "false" to disable caching
NEXUS_CACHE_ENABLED=true
