# ═══════════════════════════════════════════════
# NexusSentry — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# You only need ONE provider key — the system auto-detects
# which are available and routes accordingly.

# ── LLM Provider Keys (at least ONE required) ──
# Set whichever keys you have. System auto-selects the best one.

# Google Gemini (fastest, cheapest — recommended for demo)
GEMINI_API_KEY=your_gemini_key_here

# Groq (fast reasoning)
GROQ_API_KEY=your_groq_key_here

# OpenRouter (access to 100+ models)
OPENROUTER_API_KEY=your_openrouter_key_here

# Hugging Face Inference (fast fallback)
# Supported aliases: HUGGINGFACE_API_KEY, HUGGINGFACEHUB_API_TOKEN, HF_TOKEN
HUGGINGFACE_API_KEY=hf_your_api_key_here

# ── Response Cache (Optional) ──
# Set to "false" to disable caching
NEXUS_CACHE_ENABLED=true
